<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<add name="CampusDB"
			 connectionString="Data Source=DESKTOP-039NPLV\SQLEXPRESS1;Initial Catalog=Announcement;Integrated Security=True;"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>
	<system.web>
		<compilation debug="true" targetFramework="4.7.2"/>
